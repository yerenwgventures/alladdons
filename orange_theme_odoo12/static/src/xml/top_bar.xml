<?xml version="1.0" encoding="UTF-8" ?>
<templates id="template" xml:space="preserve">
    <t t-name="orange_theme_odoo12.MainNavBar" t-inherit="web.NavBar" t-inherit-mode="extension" owl="1">
        
    </t>


    <t t-name="orange_theme_odoo12.AppsMenu" t-inherit="web.NavBar.AppsMenu" t-inherit-mode="extension" owl="1">
        <xpath expr="//Dropdown" position="replace">
            <li class="dropdown">
                <a id="openSidebar" style="display: block; cursor: pointer; padding-right: 10px;"
                   t-on-click="openSidebar">
                    <i class="fa fa-bars fa-lg"/>
                </a>
                <a id="closeSidebar" style="display: none; cursor: pointer;" t-on-click="closeSidebar">
                    <i class="fa fa-bars fa-lg"/>
                </a>
            </li>
        </xpath>
    </t>

    <t t-name="orange_theme_odoo12.SearchResults">
        <t t-foreach="results" t-as="result">
            <div class="search_icons">
                <a t-attf-class="o-menu-search-result dropdown-item col-12 ml-auto mr-auto #{result_first ? 'active' : ''}"
                   t-attf-href="#menu_id=#{result.id}&amp;action_id=#{result.actionID}"
                   t-att-data-menu-id="result.id"
                   t-att-data-action-id="result.actionID"
                   role="menuitem">
                    <div class="app-icon">
                        <t t-if="result.webIconData">
                            <img t-if="result.webIconData.startsWith('data:image/png')"
                                 t-att-src="result.webIconData"
                                 t-att-alt="result.name"/>
                            <img t-elif="result.webIconData.startsWith('data:image/svg')"
                                 t-att-src="result.webIconData"
                                 t-att-alt="result.name"/>
                            <div t-else="" class="o_app_icon" t-att-data-icon="result.webIconData"/>
                        </t>
                        <span t-out="result.name"/>
                    </div>
                </a>
            </div>
        </t>
    </t></templates>
