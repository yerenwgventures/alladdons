<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Simple standalone configuration view for automatic payroll -->
    <record id="automatic_payroll_config_view" model="ir.ui.view">
        <field name="name">automatic.payroll.config.view</field>
        <field name="model">res.config.settings</field>
        <field name="arch" type="xml">
            <form string="Automatic Payroll Configuration">
                <sheet>
                    <group>
                        <group>
                            <field name="generate_payslip"/>
                            <field name="option" invisible="not generate_payslip"/>
                            <field name="generate_day" invisible="not generate_payslip or option in ['first','end']"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
