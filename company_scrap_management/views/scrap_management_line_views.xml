<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <!-- Tree view of scrap management line -->
    <record id="scrap_management_line_view_tree" model="ir.ui.view">
        <field name="name">scrap.management.line.view.list</field>
        <field name="model">scrap.management.line</field>
                <field name="type">list</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="product_id"/>
                <field name="dismantle_qty"/>
                <field name="useful_qty"/>
            </list>
        </field>
    </record>
<!--    Action of scrap management line-->
    <record id="scrap_management_line_action" model="ir.actions.act_window">
        <field name="name">Scrap Management Line</field>
        <field name="res_model">scrap.management.line</field>
        <field name="view_mode">list</field>
    </record>
</odoo>

