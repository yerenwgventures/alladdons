<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--        Inherited stock report picking-->
    <template id="stock_picking_report" inherit_id="stock.report_picking">
        
        <xpath expr="//tbody//tr//td"
               position="before">
            <td name="td_sequence">
                <span t-esc="1 + ml_index"/>
            </td>
        </xpath>
    </template>
</odoo>
