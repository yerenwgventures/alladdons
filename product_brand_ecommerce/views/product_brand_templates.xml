<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- This template generates a list item for a brand in a recursive manner. -->
    <template id="brands_recursive" name="Category list">
        <li class="nav-item mb-1">
            <a t-att-href="keep('/shop/brand/' + slug(c), brand=0)"
               t-attf-class="nav-link #{'active' if c.id==brand.id else ''}">
                <span t-field="c.name"/>
            </a>
        </li>
    </template>
    <!-- This template inherits and extends the 'website_sale.products' template to add a product brand filter. -->
    <template id="products_attributes" inherit_id="website_sale.products"
              active="True" name="Product Brand Filter">
<!--        
    </template>
</odoo>
