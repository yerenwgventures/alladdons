<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Kanban View for loan.request -->
    <record id="view_loan_request_kanban" model="ir.ui.view">
        <field name="name">loan.request.kanban</field>
        <field name="model">loan.request</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="state"/>
                <field name="partner_id"/>
                <field name="loan_amount"/>
                <field name="date"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="name"/>
                                        </strong>
                                    </div>
                                    <div class="o_kanban_record_body">
                                        <div>Partner: <field name="partner_id"/></div>
                                        <div>Amount: <field name="loan_amount" widget="monetary"/></div>
                                        <div>Date: <field name="date" widget="date"/></div>
                                    </div>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="state" widget="label_selection" 
                                               options="{'classes': {'draft': 'default', 'waiting_approval_1': 'warning', 'waiting_approval_2': 'info', 'approve': 'success', 'refuse': 'danger'}}"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
</odoo>
